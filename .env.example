# ─── MealMatrix – Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your real credentials.
# NEVER commit the real .env file to version control (it is in .gitignore).

# ── Flask ─────────────────────────────────────────────────────────────────────
# Generate a strong key:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-secret-key-minimum-32-chars

# !! IMPORTANT: Change this to "false" before any public deployment
FLASK_DEBUG=false

# Set to "production" on a live server (enables HTTPS-only session cookie)
FLASK_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank to use default SQLite path: backend/instance/mealmatrix.db
# For production use PostgreSQL: postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# ── Rate Limiting (optional Redis backend for multi-worker deployments) ────────
# Leave blank to use in-memory storage (fine for single-worker development)
# For production: redis://127.0.0.1:6379/0
REDIS_URL=

# ── Twilio (Phone OTP) ────────────────────────────────────────────────────────
# Get from: https://console.twilio.com/
# Leave blank to use dev-mode (OTP visible in DB, not sent via SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ── Email / SMTP (Gmail recommended) ─────────────────────────────────────────
# Use an App Password if you have 2FA enabled on Gmail:
# Guide: https://support.google.com/accounts/answer/185833
# Leave blank to use dev-mode (OTP visible in DB, not sent via email)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# ── OTP ───────────────────────────────────────────────────────────────────────
# How many minutes before an OTP expires (default: 10)
OTP_EXPIRY_MINUTES=10
